# --- Web ---
# Public URL the site is reachable at. Used for absolute links and Auth.js.
PUBLIC_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Random 32+ byte secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-real-secret

# Postgres connection string.
DATABASE_URL=postgres://themehub:themehub@localhost:5432/themehub

# Storage driver: "local" (filesystem under STORAGE_LOCAL_DIR) or "s3".
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# S3 / MinIO settings (only used when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=themehub
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- OAuth providers (optional) ---
# Leave blank to disable. If both are blank only credentials login works.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Site settings ---
SITE_NAME=themehub
SITE_TAGLINE=Theme everything.
# Comma-separated list of usernames or emails that get admin powers
ADMIN_USERS=
# Allow self-registration via the credentials provider
ALLOW_REGISTRATION=true
# Hide NSFW themes by default (users can opt in via settings)
DEFAULT_HIDE_NSFW=true
